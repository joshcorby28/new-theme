      "name": "Custom Liquid",
      "settings": {
        "custom_liquid": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<div class=\"fade-bottom-mask\"></div>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Hero Section</title>\n<style>\n@import url(\"https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Mrs+Saint+Delafield&display=swap\");\n\n@font-face {\n  src: url(\"https://fonts.cdnfonts.com/css/cabinet-grotesk\") format(\"woff2\");\n  font-family: \"PP Neue Montreal\", sans-serif;\n  font-weight: 400;\n}\n\n\n/* Variables */\n:root {\n  --primary-font: \"PP Neue Montreal\", sans-serif;\n  --secondary-font: \"Space Mono\", monospace;\n  --tetriary-font: \"Mrs Saint Delafield\", serif;\n  --primary-color: #e0e0e0;\n  --secondary-color: rgba(255, 255, 255, 0.5);\n  --quote-size: 8vw;\n  --author-size: 0.75rem;\n  --cursor-size: 20px;\n}\n\n/* Reset */\n* {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n}\n\n/* Hero section container */\n.hero-section {t\n  width: 100%;\n  height: 100vh;\n  position: relative;\n  overflow: hidden;\n  background: #111;\n  letter-spacing: -0.03em;\n  color: var(--primary-color);\n}\n\n.hero-section::before {\n  content: \"\";\n  position: absolute;\n  top: 0;\n  left: 0;\n  width: 100%;\n  height: 20%;\n  background: linear-gradient(to bottom, #222, transparent);\n  pointer-events: none;\n  z-index: 2;\n}\n\n.hero-section::after {\n  content: \"\";\n  position: absolute;\n  top: 0;\n  left: 0;\n  width: 100%;\n  height: 100%;\n  background: radial-gradient(\n    ellipse at center,\n    rgba(34,34,34,0.85) 0%,   /* darker center */\n    rgba(34, 34, 34, 0.95) 100%\n  );\n  pointer-events: none;\n  z-index: 3;\n}\n\n/* Canvas */\n.hero-section canvas {\n  position: absolute;\n  top: 0;\n  left: 0;\n  width: 100%;\n  height: 100%;\n}\n\n/* Content */\n.hero-section .content {\n  position: absolute;\n  top: 0;\n  left: 0;\n  width: 100%;\n  height: 100%;\n  display: flex;\n  flex-direction: column;\n  justify-content: center;\n  align-items: center;\n  z-index: 20;\n  padding: 20px;\n  text-align: center;\n  pointer-events: none;\n  color: var(--primary-color);\n}\n\n.quote-container {\n  max-width: 90%;\n  overflow: hidden;\n}\n\n.quote {\n  font-family: var(--primary-font);\n  font-size: var(--quote-size);\n  line-height: 0.9;\n  font-weight: 700;\n  letter-spacing: -0.03em;\n  margin-bottom: 5vh;\n  text-transform: uppercase;\n}\n\n.author {\n  font-family: var(--secondary-font);\n  font-size: var(--author-size);\n  margin-bottom: 2vh;\n  text-transform: uppercase;\n}\n\n/* Custom cursor */\n.hero-section .custom-cursor {\n  position: fixed;\n  width: var(--cursor-size);\n  height: var(--cursor-size);\n  border-radius: 50%;\n  background-color: var(--secondary-color);\n  transform: translate(-50%, -50%);\n  pointer-events: none;\n  mix-blend-mode: difference;\n  z-index: 9999;\n  transition: width 0.2s, height 0.2s;\n  will-change: transform;\n}\n\n/* Profile card */\n.hero-section .profile-card {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  padding: 16px;\n  max-width: 300px;\n  width: 100%;\n  position: fixed;\n  bottom: 16px;\n  left: 16px;\n  z-index: 999;\n  color: var(--primary-color);\n}\n\n.profile-image {\n  flex-shrink: 0;\n  width: 28px;\n  height: 28px;\n  border-radius: 50%;\n  object-fit: cover;\n}\n\n.profile-info {\n  display: flex;\n  flex-direction: column;\n  gap: 2px;\n  color: var(--primary-color);\n}\n\n.profile-name {\n  font-size: 14px;\n  font-weight: 500;\n}\n\n.profile-twitter {\n  font-size: 12px;\n  color: #71717a;\n}\n\n.profile-twitter a {\n  text-decoration: none;\n  color: inherit;\n}\n\n.profile-twitter a:hover {\n  text-decoration: underline;\n}\n</style>\n</head>\n<body>\n<section class=\"hero-section\">\n  <canvas id=\"c\"></canvas>\n\n  <div class=\"content\">\n    <div class=\"quote-container\">\n      <!-- Typewriter text at the top -->\n      <div class=\"author\" id=\"typewriter\"></div>\n\n      <!-- Quote to appear later -->\n      <div class=\"quote\" id=\"main-quote\" style=\"opacity: 0;\">FIND<br>YOUR<br>WAY</div>\n    </div>\n  </div>\n</section>\n\n<script>\n  // --- Typewriter effect ---\n  const typeText = \"DROP TWO - COMING SOON\";\n  const typewriter = document.getElementById(\"typewriter\");\n  let i = 0;\n\n  function type() {\n    if (i < typeText.length) {\n      typewriter.textContent += typeText.charAt(i);\n      i++;\n      setTimeout(type, 50); // typing speed\n    } else {\n      // After typewriter finishes, trigger the glitch effect\n      setTimeout(showGlitchQuote, 500);\n    }\n  }\n\n  setTimeout(type, 500); // start delay\n\n  // --- Glitchy/noisy reveal for main quote ---\n  const mainQuote = document.getElementById(\"main-quote\");\n  function showGlitchQuote() {\n    let frames = 20; // number of glitch frames\n    let count = 0;\n\n    function glitchFrame() {\n      mainQuote.style.opacity = 1;\n      mainQuote.style.transform = `translate(${Math.random()*10-5}px, ${Math.random()*10-5}px)`;\n      mainQuote.style.letterSpacing = `${Math.random()*0.2-0.1}em`;\n      count++;\n      if (count < frames) {\n        requestAnimationFrame(glitchFrame);\n      } else {\n        mainQuote.style.transform = `translate(0,0)`;\n        mainQuote.style.letterSpacing = '-0.03em';\n      }\n    }\n\n    glitchFrame();\n  }\n\n  // --- Canvas noise (from your code) ---\n  const canvas = document.getElementById('c');\n  const ctx = canvas.getContext('2d');\n\n  function resize() {\n    canvas.width = window.innerWidth;\n    canvas.height = window.innerHeight;\n  }\n\n  function drawNoise() {\n    const imageData = ctx.createImageData(canvas.width, canvas.height);\n    const buffer32 = new Uint32Array(imageData.data.buffer);\n    for (let i = 0; i < buffer32.length; i++) {\n      buffer32[i] = (Math.floor(Math.random() * 255) << 24) | 0xffffff;\n    }\n    ctx.putImageData(imageData, 0, 0);\n  }\n\n  function loop() {\n    drawNoise();\n    setTimeout(loop, 50);\n  }\n\n  window.addEventListener('resize', resize);\n  resize();\n  loop();\n</script>"
      }
