<section class="scroll-reveal-grid" id="scroll-grid-{{ section.id }}">

  <div class="content-wrap">

    <header class="scroll-header">
      <h1 class="fluid">{{ section.settings.heading }}</h1>
      <h2 class="fluid">{{ section.settings.subheading }}</h2>
    </header>

    <main>

      <section class="scroll-stage">

        <div class="content">
          <div class="grid">

            <!-- LAYER 1 -->
            <div class="layer layer-1">
              {% for block in section.blocks limit:6 %}
                <div {{ block.shopify_attributes }}>
                  <img
                    src="{{ block.settings.image | image_url: width: 900 }}"
                    loading="lazy"
                    alt=""
                  >
                </div>
              {% endfor %}
            </div>

            <!-- LAYER 2 -->
            <div class="layer layer-2">
              {% for block in section.blocks offset:6 limit:6 %}
                <div {{ block.shopify_attributes }}>
                  <img
                    src="{{ block.settings.image | image_url: width: 900 }}"
                    loading="lazy"
                    alt=""
                  >
                </div>
              {% endfor %}
            </div>

            <!-- LAYER 3 -->
            <div class="layer layer-3">
              {% for block in section.blocks offset:12 limit:2 %}
                <div {{ block.shopify_attributes }}>
                  <img
                    src="{{ block.settings.image | image_url: width: 900 }}"
                    loading="lazy"
                    alt=""
                  >
                </div>
              {% endfor %}
            </div>

            <!-- CENTER IMAGE -->
            <div class="scaler">
              <img
                src="{{ section.settings.center_image | image_url: width: 2000 }}"
                alt=""
              >
            </div>

          </div>
        </div>

      </section>

      <section class="scroll-end">
        <h2 class="fluid">{{ section.settings.end_text }}</h2>
      </section>

    </main>

  </div>
</section>

<style>

#scroll-grid-{{ section.id }} {
  background:black;
  color:white;
}

#scroll-grid-{{ section.id }} .content-wrap{
  overflow:hidden;
}

/* HEADER */

#scroll-grid-{{ section.id }} header{
  min-height:100vh;
  display:grid;
  align-content:center;
  padding-left:48px;
}

#scroll-grid-{{ section.id }} .fluid{
  font-size:clamp(4rem,12vw,12rem);
  line-height:.6;
  margin:0;
}

#scroll-grid-{{ section.id }} h2.fluid{
  font-size:clamp(.8rem,2vw,1.5rem);
  padding-top:48px;
}

/* SCROLL AREA */

#scroll-grid-{{ section.id }} .scroll-stage{
  min-height:240vh;
}

#scroll-grid-{{ section.id }} .content{
  position:sticky;
  top:0;
  min-height:100vh;
  display:flex;
  align-items:center;
  justify-content:center;
  overflow:hidden;
}

/* GRID */

#scroll-grid-{{ section.id }} .grid{

  --offset:0;
  --container-width:1600px;
  --gap:clamp(10px,7vw,80px);

  width:var(--container-width);
  max-width:calc(100% - 4rem);

  display:grid;
  grid-template-columns:repeat(5,1fr);
  grid-template-rows:repeat(3,auto);
  gap:var(--gap);

  position:absolute;
  top:50%;
  left:50%;
  transform:translate(-50%,-50%);
}

/* LAYERS */

#scroll-grid-{{ section.id }} .layer{
  display:grid;
  grid-column:1/-1;
  grid-row:1/-1;
  grid-template-columns:subgrid;
  grid-template-rows:subgrid;
}

/* POSITIONING */

.layer-1 div:nth-child(odd){grid-column:1;}
.layer-1 div:nth-child(even){grid-column:-2;}

.layer-2 div:nth-child(odd){grid-column:2;}
.layer-2 div:nth-child(even){grid-column:-3;}

.layer-3 div:first-child{
  grid-column:3;
  grid-row:1;
}

.layer-3 div:last-child{
  grid-column:3;
  grid-row:-1;
}

/* IMAGES */

#scroll-grid-{{ section.id }} img{
  width:100%;
  aspect-ratio:4/5;
  object-fit:cover;
  border-radius:16px;
}

/* CENTER IMAGE */

#scroll-grid-{{ section.id }} .scaler{
  grid-area:2 / 3;
  position:relative;
  z-index:5;
}

#scroll-grid-{{ section.id }} .scaler img{
  position:absolute;
  top:50%;
  left:50%;
  transform:translate(-50%,-50%);
  width:100%;
  height:100%;
}

/* END */

#scroll-grid-{{ section.id }} .scroll-end{
  min-height:100vh;
  display:grid;
  place-items:center;
}

</style>


<script type="module">

import { animate, scroll, cubicBezier } from "https://cdn.jsdelivr.net/npm/motion@11/+esm";

function initScrollGrid(section){

const image = section.querySelector(".scaler img");
const stage = section.querySelector(".scroll-stage");
const layers = section.querySelectorAll(".layer");

if(!image) return;

image.onload = () => {

const naturalWidth = image.offsetWidth;
const naturalHeight = image.offsetHeight;

const viewportWidth = window.innerWidth;
const viewportHeight = window.innerHeight;

scroll(
  animate(image,{
    width:[viewportWidth,naturalWidth],
    height:[viewportHeight,naturalHeight]
  }),
  {
    target:stage,
    offset:["start start","80% end"]
  }
);

layers.forEach((layer,index)=>{

const endOffset = `${1 - (index * 0.05)} end`;

scroll(
  animate(layer,{
    opacity:[0,0,1],
    scale:[0,0,1]
  },{
    offset:[0,.3,1],
    easing:cubicBezier(.42,0,.58,1)
  }),
  {
    target:stage,
    offset:["start start",endOffset]
  }
);

});

};

}

document.querySelectorAll(".scroll-reveal-grid").forEach(section=>{
  initScrollGrid(section);
});

document.addEventListener("shopify:section:load",e=>{
  initScrollGrid(e.target);
});

</script>


{% schema %}
{
  "name": "Scroll Grid Reveal",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "let's scroll."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Scroll animation grid"
    },
    {
      "type": "image_picker",
      "id": "center_image",
      "label": "Center Image"
    },
    {
      "type": "text",
      "id": "end_text",
      "label": "End Text",
      "default": "fin."
    }
  ],
  "blocks":[
    {
      "type":"image",
      "name":"Image",
      "settings":[
        {
          "type":"image_picker",
          "id":"image",
          "label":"Image"
        }
      ]
    }
  ],
  "max_blocks":14,
  "presets":[
    {
      "name":"Scroll Grid Reveal"
    }
  ]
}
{% endschema %}