{% liquid
  assign image_count = section.blocks.size
%}

<div class="carousel-3d-section">
  <div class="scene">
    <div class="a3d"
         style="
            --n: {{ image_count }};
            --speed: {{ section.settings.rotation_speed }}s;
         "
         {% unless section.settings.autoplay %}
         data-paused="true"
         {% endunless %}
    >
      {% for block in section.blocks %}
        {% if block.settings.image != blank %}
          <img
            class="card"
            src="{{ block.settings.image | image_url: width: 800 }}"
            alt="{{ block.settings.image.alt | escape }}"
            style="--i: {{ forloop.index0 }}"
            loading="lazy"
            {{ block.shopify_attributes }}
          >
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

<style>
.carousel-3d-section .scene,
.carousel-3d-section .a3d {
  display: grid;
}

.carousel-3d-section .scene {
  overflow: hidden;
  perspective: 35em;
  mask: linear-gradient(90deg, #0000, black 20% 80%, #0000);
}

.carousel-3d-section .a3d {
  place-self: center;
  transform-style: preserve-3d;
  animation: ry var(--speed) linear infinite;
}

.carousel-3d-section .a3d[data-paused="true"] {
  animation: none;
}

@keyframes ry {
  to { transform: rotateY(1turn); }
}

.carousel-3d-section .card {
  --w: {{ section.settings.card_width }}em;
  --ba: 1turn / var(--n);

  grid-area: 1 / 1;
  width: var(--w);
  aspect-ratio: 7 / 10;
  object-fit: cover;
  border-radius: 1.5em;
  backface-visibility: hidden;

  transform:
    rotateY(calc(var(--i) * var(--ba)))
    translateZ(calc(-1 * (.5 * var(--w) + .5em) / tan(.5 * var(--ba))));
}

@media (prefers-reduced-motion: reduce) {
  .carousel-3d-section .a3d {
    animation-duration: calc(var(--speed) * 4);
  }
}
</style>

{% schema %}
{
  "name": "3D Rotating Carousel",
  "settings": [
    {
      "type": "range",
      "id": "card_width",
      "label": "Card Width (em)",
      "min": 10,
      "max": 30,
      "step": 0.5,
      "default": 17.5
    },
    {
      "type": "range",
      "id": "rotation_speed",
      "label": "Rotation Speed (seconds)",
      "min": 10,
      "max": 120,
      "step": 2,
      "default": 32
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable rotation",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Carousel Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "3D Rotating Carousel",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}