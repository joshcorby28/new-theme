{% liquid
  assign image_count = section.blocks.size
%}

<section class="carousel-3d-section"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>

  {% if section.settings.show_overlay %}
    <div class="carousel-overlay"
      style="
        background: {{ section.settings.overlay_color }};
        opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
      ">
    </div>
  {% endif %}

  {% if section.settings.heading != blank or section.settings.text != blank %}
    <div class="carousel-content">
      {% if section.settings.heading != blank %}
        <h2>{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="rte">{{ section.settings.text }}</div>
      {% endif %}
    </div>
  {% endif %}

  <div class="scene">
    <div class="a3d"
         style="
            --n: {{ image_count }};
            --speed: {{ section.settings.rotation_speed }}s;
         "
         {% unless section.settings.autoplay %}
         data-paused="true"
         {% endunless %}
    >
      {% for block in section.blocks %}
        {% if block.settings.image != blank %}
          <img
            class="card"
            src="{{ block.settings.image | image_url: width: 1000 }}"
            alt="{{ block.settings.image.alt | escape }}"
            style="--i: {{ forloop.index0 }}"
            loading="lazy"
            {{ block.shopify_attributes }}
          >
        {% endif %}
      {% endfor %}
    </div>
  </div>

</section>

<style>
.carousel-3d-section {
  position: relative;
  overflow: hidden;
}

.carousel-3d-section .scene,
.carousel-3d-section .a3d {
  display: grid;
}

.carousel-3d-section .scene {
  perspective: 35em;
  mask: linear-gradient(90deg, #0000, black 20% 80%, #0000);
  z-index: 1;
}

.carousel-3d-section .a3d {
  place-self: center;
  transform-style: preserve-3d;
  animation: ry var(--speed) linear infinite;
}

.carousel-3d-section .a3d[data-paused="true"] {
  animation: none;
}

@keyframes ry {
  to { transform: rotateY(1turn); }
}

.carousel-3d-section .card {
  --w: {{ section.settings.card_width }}em;
  --ba: 1turn / var(--n);

  grid-area: 1 / 1;
  width: var(--w);
  aspect-ratio: 7 / 10;
  object-fit: cover;
  border-radius: 1.5em;
  backface-visibility: hidden;

  transform:
    rotateY(calc(var(--i) * var(--ba)))
    translateZ(calc(-1 * (.5 * var(--w) + .5em) / tan(.5 * var(--ba))));
}

/* Overlay */
.carousel-overlay {
  position: absolute;
  inset: 0;
  z-index: 2;
  pointer-events: none;
}

/* Content */
.carousel-content {
  position: absolute;
  inset: 0;
  z-index: 3;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 20px;
  color: #fff;
}

.carousel-content h2 {
  margin-bottom: 15px;
}

@media (prefers-reduced-motion: reduce) {
  .carousel-3d-section .a3d {
    animation-duration: calc(var(--speed) * 4);
  }
}
</style>

{% schema %}
{
  "name": "3D Rotating Carousel",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Enable overlay",
      "default": true
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 40
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your Heading Here"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Add optional supporting text here.</p>"
    },

    {
      "type": "header",
      "content": "Carousel Settings"
    },
    {
      "type": "range",
      "id": "card_width",
      "label": "Card Width (em)",
      "min": 10,
      "max": 30,
      "step": 0.5,
      "default": 17.5
    },
    {
      "type": "range",
      "id": "rotation_speed",
      "label": "Rotation Speed (seconds)",
      "min": 10,
      "max": 120,
      "step": 2,
      "default": 32
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable rotation",
      "default": true
    },

    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Carousel Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "3D Rotating Carousel",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}