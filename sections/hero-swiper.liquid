    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading min size (px)",
      "min": 20,
      "max": 60,
      "step": 2,
      "default": 28
    },
    {
      "type": "range",
      "id": "heading_size_max",
      "label": "Heading max size (px)",
      "min": 40,
      "max": 200,
      "step": 4,
