        { "value": "0.02", "label": "Wide" },
        { "value": "0.05", "label": "Wider" },
        { "value": "0.1", "label": "Widest" }
      ],
      "default": "-0.02"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading size (px)",
      "min": 12,
      "max": 28,
      "step": 1,
      "default": 16
    },
    {
